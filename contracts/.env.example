# Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Irys Network RPC URLs
IRYS_TESTNET_RPC=https://testnet-rpc.irys.xyz
IRYS_MAINNET_RPC=https://rpc.irys.xyz

# Irys API Configuration
IRYS_API_KEY=your_irys_api_key

# Irys Interface Contract Addresses (will be provided by Irys team)
IRYS_DATA_STORE=0x0000000000000000000000000000000000000001
IRYS_VM=0x0000000000000000000000000000000000000002

# Gas Settings
GAS_PRICE=1000000000
GAS_LIMIT=8000000

# Verification
ETHERSCAN_API_KEY=dummy_for_irys_explorer

# Environment
NODE_ENV=development